{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "lib": ["ES2020"],
    "outDir": "./dist",
    "rootDir": "../",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "paths": {
      "@/*": ["../*"]
    }
  },
  "include": [
    "./**/*.ts",
    "../lib/server.ts",
    "../lib/ai/**/*.ts",
    "../lib/deepgram/**/*.ts",
    "../lib/media/**/*.ts",
    "../lib/queue/**/*.ts"
  ],
  "exclude": ["node_modules", "../node_modules"]
}
